# Claude API
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Supabase PostgreSQL
# Create project at: https://supabase.com/dashboard/projects
# Get URL & key from: Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Telegram Bot (Phase 1 + 3)
# Create bot with: https://t.me/BotFather
# Follow instructions to get BOT_TOKEN
TELEGRAM_BOT_TOKEN=
# Your chat ID (optional, auto-detected if not set)
TELEGRAM_CHAT_ID=

# NewsAPI (optional, for MVP)
# Register at: https://newsapi.org/register
# Free tier: 100 requests/day
NEWSAPI_KEY=

# Reddit API (optional, for trends)
# Create app at: https://www.reddit.com/prefs/apps
# Get CLIENT_ID and CLIENT_SECRET
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# LinkedIn API (Phase 1)
# Register at: https://www.linkedin.com/developers/apps
# Get CLIENT_ID and CLIENT_SECRET
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter/X API (Phase 1, optional)
# Register at: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# === PHASE 2: VIDEO + YOUTUBE SHORTS ===

# ElevenLabs Text-to-Speech (Phase 2)
# Register at: https://elevenlabs.io/sign-up
# Get API key from: Account > API Keys
ELEVENLABS_API_KEY=
# Voice ID (default: eleven_monolingual_v1 for English)
ELEVENLABS_VOICE_ID=eleven_monolingual_v1

# YouTube API (Phase 2 - YouTube Shorts)
# Create OAuth credentials at: https://console.cloud.google.com
# Enable YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Get refresh token via OAuth flow (see docs)
YOUTUBE_REFRESH_TOKEN=
# public | unlisted | private — default unlisted (real upload, not publicly listed)
YOUTUBE_PRIVACY_STATUS=unlisted

# Pexels stock footage (Phase 2 — free tier, no card required)
# Register at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Video rendering (Phase 2)
# REQUIRES the `ffmpeg` binary installed and on PATH. Without it, the
# pipeline still runs but only produces audio+subtitle metadata, no real
# .mp4 (videoAssembler logs a warning and CompiledVideo.filePath is null).
# macOS: brew install ffmpeg-full && brew link --overwrite ffmpeg-full
#   (plain `ffmpeg` formula lacks libass -> no burned-in subtitles)
# Debian/Ubuntu: apt install ffmpeg
VIDEO_WATERMARK_TEXT=AInfluencer
VIDEO_OUTPUT_DIR=./output

# === PHASE 3: USER CONTROL + ANALYTICS ===
# (Telegram bot commands already configured above)

# === CONFIGURATION FLAGS ===

# Publishing mode
# true = auto-publish to platforms (requires credentials)
# false = draft only (safe default for testing)
PUBLISH_LIVE=false

# Video publishing
# true = generate and publish video content
# false = text only
PUBLISH_VIDEO=false

# Hybrid Profile System
# true = enable hybrid content rotation (AI + Electrical topics)
# false = trending news only
HYBRID_ENABLED=true
# 1 of every N posts is hybrid (default: 1 in 5)
HYBRID_RATIO=5

# Environment & Logging
NODE_ENV=development
LOG_LEVEL=debug
# true = enable daily scheduled posting
SCHEDULER_ENABLED=false
