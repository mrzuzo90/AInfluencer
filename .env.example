# Claude API
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Supabase PostgreSQL
# Create project at: https://supabase.com/dashboard/projects
# Get URL & key from: Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Telegram Bot
# Create bot with: https://t.me/BotFather
# Follow instructions to get BOT_TOKEN
TELEGRAM_BOT_TOKEN=

# NewsAPI (optional, for MVP)
# Register at: https://newsapi.org/register
# Free tier: 100 requests/day
NEWSAPI_KEY=

# Reddit API (optional, for trends)
# Create app at: https://www.reddit.com/prefs/apps
# Get CLIENT_ID and CLIENT_SECRET
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# LinkedIn API (Phase 1)
# Register at: https://www.linkedin.com/developers/apps
# Get CLIENT_ID and CLIENT_SECRET
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter/X API (Phase 1, optional)
# Register at: https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=

# Environment
NODE_ENV=development
LOG_LEVEL=debug
